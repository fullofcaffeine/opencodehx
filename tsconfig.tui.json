{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "./src-gen/tui",
    "outDir": "./dist-tui",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid"
  },
  "include": [
    "src-gen/tui/**/*.ts",
    "src-gen/tui/**/*.tsx"
  ]
}
