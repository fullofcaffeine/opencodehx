{
  "name": "opencodehx",
  "private": true,
  "type": "module",
  "version": "0.1.0-beta.0",
  "description": "Haxe-authored OpenCode port emitting TypeScript through genes-ts.",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/build/clean.mjs",
    "build:haxe": "haxe hxml/opencodehx.node.genes-ts.hxml",
    "typecheck": "tsc -p tsconfig.json",
    "copy:resources": "node scripts/build/copy-resources.mjs",
    "inventory:matrix": "node scripts/inventory/build-parity-matrix.mjs",
    "build": "npm run clean && npm run build:haxe && npm run copy:resources && npm run typecheck",
    "smoke": "node --enable-source-maps dist/index.js",
    "transcript:parity": "npm run build && node scripts/harness/transcript-parity.mjs",
    "cli:smoke": "npm run build && node scripts/harness/cli-smoke.mjs",
    "test:haxe:unit": "node scripts/harness/haxe-unit-specs.mjs",
    "tui:scaffold": "node scripts/harness/tui-scaffold.mjs",
    "format:haxe": "bash scripts/lint/hx_format_guard.sh --write",
    "format:haxe:check": "bash scripts/lint/hx_format_guard.sh",
    "security:gitleaks": "bash scripts/security/run-gitleaks.sh",
    "security:gitleaks:staged": "bash scripts/security/run-gitleaks.sh --staged",
    "hooks:install": "bash scripts/hooks/install.sh",
    "public:precommit": "npm run format:haxe:check && npm run security:gitleaks",
    "ci:version-sync": "node scripts/ci/version-sync-check.mjs",
    "ci:release-contracts": "node scripts/ci/release-contracts-check.mjs",
    "ci:full": "npm run ci:version-sync && npm run ci:release-contracts && npm run format:haxe:check && npm run build && npm run test:haxe:unit && npm run smoke && npm run tui:scaffold",
    "test": "npm run ci:version-sync && npm run ci:release-contracts && npm run format:haxe:check",
    "release:sync-versions": "node scripts/release/sync-versions.mjs",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fullofcaffeine/opencodehx.git"
  },
  "imports": {
    "#opencodehx/smoke-resource": {
      "types": "./src-gen/resources/smoke-resource.json",
      "default": "./dist/resources/smoke-resource.json"
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.1",
    "@types/ws": "^8.18.1",
    "bun": "1.3.14",
    "lix": "^15.12.4",
    "semantic-release": "^24.2.5",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.96",
    "@ai-sdk/anthropic": "^2.0.83",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@aws-sdk/credential-providers": "^3.993.0",
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.3.0",
    "@lydell/node-pty": "1.2.0-beta.10",
    "@opentui/core": "0.1.99",
    "@opentui/solid": "0.1.99",
    "ai": "^6.0.168",
    "ai-gateway-provider": "^3.1.3",
    "better-sqlite3": "^12.11.1",
    "effect": "^4.0.0-beta.48",
    "hono": "^4.12.26",
    "jsonc-parser": "^3.3.1",
    "solid-js": "1.9.11",
    "toml": "^4.1.1",
    "tree-sitter-bash": "0.25.0",
    "tree-sitter-powershell": "0.25.10",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.1.8"
  },
  "release": {
    "branches": [
      {
        "name": "main",
        "prerelease": "beta"
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "node scripts/release/sync-versions.mjs ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "README.md",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
