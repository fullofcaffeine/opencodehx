-lib genes-ts
-cp src
--main opencodehx.Main

# Haxe still uses -js because genes-ts runs on the JS platform.
-js src-gen/index.ts

# Emit TypeScript via genes-ts.
-D genes.ts
-D genes.ts.lower_private_helpers

# Keep the initial scaffold small and reflection-light.
-D genes.ts.minimal_runtime

-dce full
