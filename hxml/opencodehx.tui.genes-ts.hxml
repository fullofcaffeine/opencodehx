-lib genes-ts
-cp src
--main opencodehx.tui.TuiScaffold

# TSX scaffold build. The output extension tells genes-ts to print JSX markers
# as TSX instead of lowering them to createElement calls.
-js src-gen/tui/index.tsx

-D genes.ts
-D genes.ts.lower_private_helpers
-D genes.ts.minimal_runtime
-D genes.ts.jsx_import_source=@opentui/solid

-dce full
