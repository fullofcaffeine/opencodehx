{
  "excludes": [
    "\\.git",
    "\\.beads",
    "\\.haxelib",
    "node_modules",
    "dist",
    "src-gen",
    "generated",
    "test/\\.generated",
    "vendor"
  ],
  "indentation": {
    "character": "tab",
    "tabWidth": 4,
    "trailingWhitespace": false
  },
  "lineEnds": {
    "lineEndCharacter": "lf"
  },
  "emptyLines": {
    "finalNewline": true
  }
}

